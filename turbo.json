{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "outputs": ["dist/**"]
    },

    "coverage": {
      "dependsOn": ["^coverage"]
    },

    "check-types": {
      "dependsOn": ["^check-types"]
    },

    "lint": {
      "dependsOn": ["^lint"]
    },

    "dev": {
      "persistent": true,
      "cache": false
    }
  }
}
